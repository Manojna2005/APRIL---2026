class Solution:
    def minMirrorPairDistance(self, nums: List[int]) -> int:
        def reverse(x):
            return int(str(x)[::-1])
        last = {}
        ans = float('inf')    
        for j, x in enumerate(nums):
            if x in last:
                ans = min(ans, j - last[x])         
            rev = reverse(x)
            last[rev] = j       
        return ans if ans != float('inf') else -1
