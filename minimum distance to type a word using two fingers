class Solution:
    def minimumDistance(self, word: str) -> int:
        def dist(a, b):
            if a == -1:
                return 0
            x1, y1 = divmod(a, 6)
            x2, y2 = divmod(b, 6)
            return abs(x1 - x2) + abs(y1 - y2)
        n = len(word)
        dp = [[float('inf')] * 26 for _ in range(n)]
        first = ord(word[0]) - ord('A')
        for j in range(26):
            dp[0][j] = 0
        for i in range(1, n):
            cur = ord(word[i]) - ord('A')
            prev = ord(word[i-1]) - ord('A')
            for j in range(26):
                dp[i][j] = min(dp[i][j], dp[i-1][j] + dist(prev, cur))
                dp[i][prev] = min(dp[i][prev], dp[i-1][j] + dist(j, cur))
        return min(dp[n-1]) 
